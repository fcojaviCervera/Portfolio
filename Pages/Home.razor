@page "/"

<PageTitle>Francisco Javier Cervera — Portfolio</PageTitle>

<section id="inicio" class="hero">
    <h1>Francisco Javier Cervera Muñoz</h1>
    <p class="subtitle">Desarrollador .NET</p>
    <div class="hero-actions">
        <a href="#proyectos">Ver proyectos</a>
        <a href="#contacto">Contacto</a>
    </div>
</section>

<section id="sobre-mi">
    <h2>Sobre mí</h2>
    <p>
        Ingeniero de software especializado en desarrollo .NET, con experiencia
        en backend, bases de datos y aplicaciones de gestión. (Edita esto a tu gusto.)
    </p>
</section>

<section id="experiencia">
    <h2>Experiencia</h2>
    <div class="timeline">

        @foreach (var item in CvData.Experience)
        {
            <div class="timeline-item">

                <span class="timeline-dot"></span>
                <div class="timeline-content">

                    <h3> @item.Role</h3>
                    <p class="company"> @item.Company @(item.Location is not null ? $" · {item.Location}" : "")</p>
                    <p class="period"> @item.Period </p>
                    @if (item.Description is not null)
                    {
                        <p class="desc"> @item.Description</p>
                    }

                </div>
            </div>
        }
    </div>

</section>

<section id="tecnologias">
    <h2>Tecnologías</h2>
    <p>(Próximamente: tu stack con iconos.)</p>
</section>

<section id="proyectos">
    <h2>Proyectos</h2>
    <p>(Próximamente: tarjetas de proyectos.)</p>
</section>

<section id="contacto">
    <h2>Contacto</h2>
    <p>Email: franciscojavier.cervera7@gmail.com</p>
    <p>LinkedIn: linkedin.com/in/franciscojavier-cervera-muñoz</p>
    <p>Murcia, España</p>
</section>